{
  "name": "e2e-demo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:selenium": "node tests/selenium/checkout.test.js --headless",
    "test:selenium:visible": "node tests/selenium/checkout.test.js",
    "test:puppeteer": "node tests/puppeteer/checkout.test.js",
    "test:puppeteer:pom": "node tests/puppeteer-pom/checkout.test.js",
    "test:cypress": "npx cypress run --config-file tests/cypress.config.js --spec tests/cypress/e2e/checkout.cy.js",
    "test:cypress:open": "npx cypress open --config-file tests/cypress.config.js",
    "test:playwright": "npx playwright test --config tests/playwright.config.js tests/playwright/checkout.spec.js",
    "test:playwright:ui": "npx playwright test --config tests/playwright.config.js --ui",
    "test:stagehand": "node --env-file=.env tests/stagehand/checkout.test.js",
    "test:stagehand:cloud": "node --env-file=.env tests/stagehand/checkout.browserbase.test.js"
  },
  "dependencies": {
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@browserbasehq/stagehand": "^3.1.0",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.2.0",
    "cypress": "^15.11.0",
    "puppeteer": "^24.37.5",
    "selenium-webdriver": "^4.41.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  }
}
